---
import Layout from "../layouts/Layout.astro";
import Icon from "../components/Icon.astro";
import { getCategoriesWithRandomApps, getAppConfig } from "../lib/query";
import { getApps } from "../lib/data";
import { getCurrentLanguage, getLocalizedStrings } from "../lib/i18n";

Astro.response.headers.set('Cache-Control', 'public, max-age=600, s-maxage=1800');

const allApps = getApps();
const categoryApps = getCategoriesWithRandomApps(4);
const categoryCounts: Record<string, number> = {};
for (const app of allApps) {
  for (const cat of app.categories) {
    categoryCounts[cat] = (categoryCounts[cat] || 0) + 1
  }
}
const categories = Object.keys(categoryApps).sort((a, b) => (categoryCounts[b] || 0) - (categoryCounts[a] || 0));

const currentLanguage = await getCurrentLanguage(Astro.url, Astro.request);
const translations = getLocalizedStrings(currentLanguage);
---

<Layout>
  <div class="container mx-auto px-4 py-6">
    <!-- All Apps tile -->
    <div class="mb-8">
      <a
        href="/apps"
        class="group relative block p-10 bg-surface border border-border rounded-3xl hover:border-primary-500 transition-all duration-300"
      >
        <div class="text-center relative">
          <div class="mb-3">
            <div
              class="w-16 h-16 mx-auto bg-primary-50/80 rounded-2xl flex items-center justify-center"
            >
              <svg class="w-7 h-7 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 6.878V6a2.25 2.25 0 012.25-2.25h7.5A2.25 2.25 0 0118 6v.878m-12 0c.235-.083.487-.128.75-.128H6m12 0A2.25 2.25 0 0118.75 9v.878M6 6.878a2.25 2.25 0 00-.878.5L3.22 9.22a2.25 2.25 0 00-.47 2.372L4.5 18.5a2.25 2.25 0 002.121 1.5h10.758a2.25 2.25 0 002.121-1.5l1.748-6.908a2.25 2.25 0 00-.47-2.372l-1.902-1.842a2.25 2.25 0 00-.878-.5M6 6.878V6h12v.878" />
              </svg>
            </div>
          </div>
          <h2 class="text-xl font-semibold text-text mb-1">
            {translations["allCategories"]}
          </h2>
          <p class="text-text-subtle text-xs mb-5">
            {allApps.length} {translations["apps"] || "apps"}
          </p>
          <span
            class="inline-flex items-center px-5 py-2.5 bg-primary-600 text-on-primary text-sm font-medium rounded-full hover:bg-primary-500 transition-colors duration-200"
          >
            {translations["browseAllApps"]}
              <svg
                class="w-4 h-4 ml-2 group-hover:translate-x-0.5 transition-transform duration-200"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"></path>
              </svg>
          </span>
        </div>
      </a>
    </div>

    <!-- Category tiles grid -->
    <div
      class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4"
    >
      {
        categories.map((cat: string) => (
          <a
            href={`/apps?category=${cat}`}
            class="group relative block p-5 bg-surface border border-border rounded-3xl hover:border-primary-500 transition-all duration-300"
          >
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-sm font-semibold text-text">
                {translations[cat]}
              </h3>
              <div class="flex items-center gap-1.5">
                <span class="text-xs text-text-subtle">{categoryCounts[cat]}</span>
                <svg
                  class="w-3.5 h-3.5 text-text-subtle group-hover:text-primary-400 group-hover:translate-x-0.5 transition-all duration-200"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              </div>
            </div>
            <div class="flex flex-wrap gap-2">
              {categoryApps[cat].map((app) => (
                <Icon
                  src={app.icon}
                  alt={getAppConfig(app)[0].name}
                  width={32}
                  height={32}
                  className="rounded-xl opacity-80 group-hover:opacity-100 transition-opacity duration-300"
                />
              ))}
            </div>
          </a>
        ))
      }
    </div>
  </div>
</Layout>
